-- ========================================================
-- CHỨC NĂNG 1: ESP TRÁI ÁC QUỶ
-- ========================================================
local espFolder = Instance.new("Folder", game.CoreGui)

local function createESP(object)
    if not object:FindFirstChild("FruitESP") then
        local bbg = Instance.new("BillboardGui", espFolder)
        bbg.Name = "FruitESP"
        bbg.Adornee = object
        bbg.Size = UDim2.new(0, 200, 0, 50)
        bbg.AlwaysOnTop = true
        
        local txt = Instance.new("TextLabel", bbg)
        txt.Size = UDim2.new(1, 0, 1, 0)
        txt.BackgroundTransparency = 1
        txt.Text = "[🍇] " .. object.Name
        txt.TextColor3 = Color3.fromRGB(255, 0, 255)
        txt.Font = Enum.Font.SourceSansBold
        txt.TextSize = 16
    end
end

local espEnabled = false
CreateFunctionButton("EspFruitBtn", "ESP Trái Ác Quỷ", function(state)
    espEnabled = state
    if not espEnabled then
        espFolder:ClearAllChildren()
    else
        -- Quét trái có sẵn trên map
        for _, v in pairs(workspace:GetChildren()) do
            if v:IsA("Tool") or (v:IsA("Model") and string.find(string.lower(v.Name), "fruit")) then
                createESP(v)
            end
        end
    end
end)

-- Lắng nghe trái mới xuất hiện cho ESP
workspace.ChildAdded:Connect(function(child)
    if espEnabled then
        task.wait(0.5)
        if child:IsA("Tool") or (child:IsA("Model") and string.find(string.lower(child.Name), "fruit")) then
            createESP(child)
        end
    end
end)


-- ========================================================
-- CHỨC NĂNG 2: BAY NHẶT TRÁI SPAWN (Tự động bay tới)
-- ========================================================
local function getFruitSpawn()
    for _, v in pairs(workspace:GetChildren()) do
        if v:IsA("Tool") and string.find(string.lower(v.Name), "fruit") then
            return v
        end
    end
    return nil
end

local autoSpawnEnabled = false
CreateFunctionButton("AutoSpawnBtn", "Bay Nhặt Trái Spawn", function(state)
    autoSpawnEnabled = state
    while autoSpawnEnabled do
        task.wait(0.5)
        local p = game.Players.LocalPlayer
        local character = p.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            local fruit = getFruitSpawn()
            if fruit and fruit:FindFirstChild("Handle") then
                -- Bay mượt bằng cách đổi CFrame trực tiếp hoặc Tween (ở đây dùng CFrame trực tiếp để nhanh gọn)
                character.HumanoidRootPart.CFrame = fruit.Handle.CFrame + Vector3.new(0, 2, 0)
            end
        end
    end
end)


-- ========================================================
-- CHỨC NĂNG 3: TELE TRÁI BỊ VỨT (Dịch chuyển tới trái rơi)
-- ========================================================
-- Trong Blox Fruits, trái bị vứt (dropped) thường nằm trong Workspace dưới dạng Model hoặc Tool giống trái spawn.
-- Chức năng này sẽ quét liên tục và đưa bạn tới vị trí đó ngay lập tức.
local teleDroppedEnabled = false
CreateFunctionButton("TeleDroppedBtn", "Tele Trái Bị Vứt", function(state)
    teleDroppedEnabled = state
    while teleDroppedEnabled do
        task.wait(0.5)
        local p = game.Players.LocalPlayer
        local character = p.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            for _, v in pairs(workspace:GetChildren()) do
                -- Trái vứt thường là một Model chứa chữ "Fruit" hoặc một cây Tool rơi tự do
                if (v:IsA("Model") or v:IsA("Tool")) and string.find(string.lower(v.Name), "fruit") then
                    local targetPart = v:FindFirstChild("Handle") or v:FindFirstChildWhichIsA("BasePart")
                    if targetPart then
                        character.HumanoidRootPart.CFrame = targetPart.CFrame
                        break -- Ưu tiên nhặt từng trái một
                    end
                end
            end
        end
    end
end)
